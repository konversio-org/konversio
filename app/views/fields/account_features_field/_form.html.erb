<% feature_groups = [
  [t('super_admin.account_features.standard_features'), field.standard_features],
  [t('super_admin.account_features.pilot_ai'), field.pilot_features]
] %>

<div class="field-unit__label">
  <%= f.label :selected_feature_flags, t('super_admin.account_features.feature_access') %>
</div>

<div class="field-unit__field space-y-5">
  <%# Sentinel value to handle all checkboxes being unchecked %>
  <input type="hidden" name="account[selected_feature_flags][]" value="__sentinel__">

  <% feature_groups.each do |title, features| %>
    <% pilot_group = title == t('super_admin.account_features.pilot_ai') %>

    <fieldset class="overflow-hidden rounded-md border border-slate-200 bg-white">
      <legend class="sr-only"><%= title %></legend>

      <div class="border-b border-slate-200 bg-slate-50 px-4 py-3">
        <h4 class="text-sm font-semibold text-slate-900">
          <%= title %>
        </h4>
      </div>

      <div class="divide-y divide-slate-100">
        <% features.each do |feature| %>
          <% enabled = field.feature_enabled?(feature) %>
          <% pilot_master = field.pilot_master_feature?(feature) %>
          <% inactive_pilot_subfeature = pilot_group && !pilot_master && !field.pilot_master_enabled? %>
          <% row_classes =
            if pilot_master
              'bg-blue-50 hover:bg-blue-100'
            elsif inactive_pilot_subfeature
              'bg-slate-50 hover:bg-slate-100'
            else
              'bg-white hover:bg-slate-50'
            end %>

          <label class="flex cursor-pointer items-center justify-between gap-4 px-4 py-3 transition <%= row_classes %>">
            <span class="min-w-0">
              <span class="block truncate text-sm font-medium <%= inactive_pilot_subfeature ? 'text-slate-500' : 'text-slate-900' %>">
                <%= field.feature_display_name(feature) %>
              </span>
              <span class="mt-0.5 block truncate font-mono text-[11px] text-slate-400">
                <%= field.feature_name(feature) %>
              </span>
            </span>

            <input
              type="checkbox"
              name="account[selected_feature_flags][]"
              value="<%= field.feature_name(feature) %>"
              <%= 'checked' if enabled %>
              class="h-4 w-4 shrink-0 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
            >
          </label>
        <% end %>
      </div>
    </fieldset>
  <% end %>
</div>
