<% content_for(:title) do %>
  LLM Settings
<% end %>

<header class="main-content__header" role="banner">
  <h1 class="main-content__page-title" id="page-title">
    <%= content_for(:title) %>
  </h1>
</header>

<section class="main-content__body">
  <% if flash[:notice] %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <% if @error.present? %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <%= @error %>
    </div>
  <% end %>

  <% if @test_results.present? %>
    <div class="mb-4 border border-slate-200 rounded p-3">
      <h3 class="text-sm font-semibold mb-2">Test results</h3>
      <ul class="space-y-1 text-sm">
        <% @test_results.each do |slot, result| %>
          <li>
            <span class="inline-block w-20 font-mono text-xs"><%= slot %></span>
            <% if result[:ok] %>
              <span class="inline-block px-2 py-0.5 rounded bg-green-100 text-green-800 text-xs">PASS</span>
            <% else %>
              <span class="inline-block px-2 py-0.5 rounded bg-red-100 text-red-800 text-xs">FAIL</span>
            <% end %>
            <span class="ml-2 text-slate-600"><%= result[:message] %></span>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @dimension_warning %>
    <div class="bg-yellow-100 border border-yellow-400 text-yellow-800 px-4 py-3 rounded mb-4">
      <strong>Embedding dimension mismatch.</strong>
      The embedding slot is set to <code><%= @dimension_warning[:model] %></code> (<%= @dimension_warning[:new_dim] %> dims),
      but stored vectors were generated at <%= @dimension_warning[:stored_dim] %> dims. Switching will break pgvector queries
      against existing rows. Re-embed your corpus or revert the model.
    </div>
  <% end %>

  <p class="text-sm text-slate-600 mb-4">
    API keys are read from environment variables and never edited through this page.
    Configure a provider by setting <code>PILOT_LLM_&lt;SLUG&gt;_API_KEY</code> (plus
    <code>_ENDPOINT</code>, <code>_LABEL</code>, <code>_OPENAI_COMPATIBLE</code>, <code>_CAPABILITIES</code> for custom slugs).
    Account-level OpenAI integration keys override the chat slot's <code>api_key</code> only — embedding and audio always use the slot's system key.
  </p>

  <h2 class="text-base font-semibold mt-6 mb-2">Provider Status</h2>
  <table class="w-full text-sm mb-6 border border-slate-100 rounded">
    <thead class="bg-slate-50">
      <tr>
        <th class="text-left p-2">Slug</th>
        <th class="text-left p-2">Label</th>
        <th class="text-left p-2">Endpoint</th>
        <th class="text-left p-2">Capabilities</th>
        <th class="text-left p-2">Compatible mode</th>
        <th class="text-left p-2">Status</th>
      </tr>
    </thead>
    <tbody>
      <% @providers.each do |provider| %>
        <tr class="border-t border-slate-100">
          <td class="p-2 font-mono"><%= provider[:slug] %></td>
          <td class="p-2"><%= provider[:label] %></td>
          <td class="p-2 font-mono text-xs"><%= provider[:endpoint].presence || '—' %></td>
          <td class="p-2 text-xs">
            <% provider[:capabilities].each do |cap| %>
              <span class="inline-block px-2 py-0.5 rounded bg-slate-100 text-slate-700 mr-1"><%= cap %></span>
            <% end %>
          </td>
          <td class="p-2"><%= provider[:openai_compatible] ? 'openai-compatible' : 'native openai' %></td>
          <td class="p-2">
            <% if provider[:available] %>
              <span class="inline-block px-2 py-1 rounded bg-green-100 text-green-800 text-xs">Configured</span>
            <% else %>
              <span class="inline-block px-2 py-1 rounded bg-slate-100 text-slate-700 text-xs">
                <% if provider[:misconfigured_reason] == 'Missing endpoint' %>
                  Set PILOT_LLM_<%= provider[:slug].to_s.upcase %>_ENDPOINT
                <% else %>
                  Set PILOT_LLM_<%= provider[:slug].to_s.upcase %>_API_KEY
                <% end %>
              </span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= form_with url: super_admin_llm_settings_path, method: :patch, local: true, id: 'llm-settings-form' do |form| %>
    <h2 class="text-base font-semibold mb-2">Preset</h2>
    <p class="text-xs text-slate-500 mb-3">
      Select a preset to fill all three slots atomically. Touching anything in Advanced switches you to "Custom".
    </p>
    <div class="space-y-2 mb-6">
      <% @presets.each do |preset| %>
        <label class="flex items-start gap-2 p-2 border border-slate-100 rounded <%= preset[:applicable] ? '' : 'opacity-60' %>">
          <%= form.radio_button :preset, preset[:slug],
              checked: @current_preset == preset[:slug],
              disabled: !preset[:applicable],
              data: { 'llm-preset': true } %>
          <span>
            <span class="font-medium"><%= preset[:label] %></span>
            <span class="ml-2 text-xs text-slate-500 font-mono"><%= preset[:slug] %></span>
            <% unless preset[:applicable] %>
              <span class="ml-2 text-xs text-red-600">
                Missing provider(s): <%= preset[:missing_providers].join(', ') %>
              </span>
            <% end %>
            <div class="text-xs text-slate-500 mt-1">
              <% Llm::Presets::SLOTS.each do |slot| %>
                <span class="mr-3"><span class="font-mono"><%= slot %></span>: <%= preset[slot][:provider] %> / <%= preset[slot][:model] %></span>
              <% end %>
            </div>
          </span>
        </label>
      <% end %>

      <label class="flex items-center gap-2 p-2 border border-slate-100 rounded">
        <%= form.radio_button :preset, Llm::Presets::CUSTOM_SLUG,
            checked: @current_preset == Llm::Presets::CUSTOM_SLUG,
            data: { 'llm-preset': true } %>
        <span class="font-medium">Custom</span>
        <span class="text-xs text-slate-500">— configure each slot individually below.</span>
      </label>
    </div>

    <h2 class="text-base font-semibold mb-2">Advanced (per-slot)</h2>
    <p class="text-xs text-slate-500 mb-3">
      Each slot's dropdown lists only providers that are available and declare that slot's capability.
    </p>
    <table class="w-full text-sm mb-4 border border-slate-100 rounded">
      <thead class="bg-slate-50">
        <tr>
          <th class="text-left p-2">Slot</th>
          <th class="text-left p-2">Provider</th>
          <th class="text-left p-2">Model</th>
          <th class="text-left p-2">Status</th>
        </tr>
      </thead>
      <tbody>
        <% Llm::Presets::SLOTS.each do |slot| %>
          <tr class="border-t border-slate-100">
            <td class="p-2 font-mono"><%= slot %></td>
            <td class="p-2">
              <% candidates = @slots[slot][:candidates] %>
              <% if candidates.empty? %>
                <span class="text-xs text-red-700">No available provider supports <%= slot %></span>
              <% else %>
                <select name="slots[<%= slot %>][provider]" data-llm-slot="<%= slot %>"
                        class="border border-slate-200 p-1 rounded font-mono text-xs">
                  <% candidates.each do |slug| %>
                    <option value="<%= slug %>" <%= 'selected' if @slots[slot][:provider] == slug %>><%= slug %></option>
                  <% end %>
                </select>
              <% end %>
            </td>
            <td class="p-2">
              <input type="text" name="slots[<%= slot %>][model]"
                     value="<%= @slots[slot][:model] %>" data-llm-slot="<%= slot %>"
                     class="border border-slate-200 p-1 rounded w-full max-w-md font-mono text-xs" />
            </td>
            <td class="p-2 text-xs text-slate-500">
              <% if slot == :audio %>
                Plumbed, not yet consumed
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="flex gap-2">
      <%= form.submit 'Save', class: 'bg-woot-500 text-white px-4 py-2 rounded' %>
    </div>
  <% end %>

  <%= form_with url: test_super_admin_llm_settings_path, method: :post, local: true do |form| %>
    <div class="mt-2">
      <%= form.submit 'Test all slots', class: 'bg-slate-100 text-slate-800 border border-slate-200 px-4 py-2 rounded' %>
      <span class="text-xs text-slate-500 ml-2">Issues a minimal round-trip per slot. Nothing is persisted.</span>
    </div>
  <% end %>

  <script>
    (function () {
      var form = document.getElementById('llm-settings-form');
      if (!form) return;
      var customRadio = form.querySelector('input[name="preset"][value="custom"]');
      if (!customRadio) return;
      var slotInputs = form.querySelectorAll('[data-llm-slot]');
      slotInputs.forEach(function (el) {
        el.addEventListener('change', function () { customRadio.checked = true; });
        el.addEventListener('input', function () { customRadio.checked = true; });
      });
    })();
  </script>
</section>
